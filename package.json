{
  "name": "sounds-of-growth-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "deploy": "npm run deploy:full",
    "deploy:full": "git pull && npm ci && npm run prisma:sync && npm run build && pm2 restart sog --update-env",
    "deploy:quick": "npm run prisma:sync && npm run build && pm2 restart sog --update-env",
    "logs": "pm2 logs sog --lines 100",
    "prisma:sync": "prisma generate && prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "reset:admin": "tsx scripts/reset-admin.ts",
    "backfill:student-passwords": "tsx scripts/backfill-student-passwords.ts"
  },
  "dependencies": {
    "@formatjs/intl": "^3.1.6",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@next/mdx": "15.4.6",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tiptap/extension-link": "^2.26.1",
    "@tiptap/react": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.1",
    "edge-runtime": "^4.0.1",
    "lucide-react": "^0.460.0",
    "next": "15.4.6",
    "next-auth": "^4.24.11",
    "next-intl": "^4.3.4",
    "nodemailer": "^6.9.14",
    "prisma": "^6.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.4",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

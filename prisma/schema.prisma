// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
 
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?   @db.Text
  hashedPassword String?
  firstName      String
  lastName       String
  phone          String?
  locale         String    @default("en")
  role           Role      @default(STUDENT)
  mustChangePassword Boolean @default(false)
  teacher        Teacher?
  student        Student?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
}

model Teacher {
  id          String       @id @default(cuid())
  user        User         @relation(fields: [userId], references: [id])
  userId      String       @unique
  students    Student[]
  lessons     Lesson[]
  summerCamps SummerCamp[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Student {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id])
  userId         String   @unique
  teacher        Teacher  @relation(fields: [teacherId], references: [id])
  teacherId      String
  dateOfBirth    DateTime
  address        String?  @db.Text
  lat            Float?
  lng            Float?
  lessons         Lesson[]
  cancelRequests  LessonCancellationRequest[]
  campEnrollments CampEnrollment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ClassType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lessons   Lesson[]
}

enum LessonStatus {
  CREATED
  CANCELLED
  COMPLETED
}

enum RecurrenceType {
  WEEKLY
  BIWEEKLY
}

model Lesson {
  id               String          @id @default(cuid())
  teacher          Teacher         @relation(fields: [teacherId], references: [id])
  teacherId        String
  student          Student         @relation(fields: [studentId], references: [id])
  studentId        String
  classType        ClassType       @relation(fields: [classTypeId], references: [id])
  classTypeId      String
  startsAtUtc      DateTime
  durationMin      Int
  timezone         String
  recurrence       RecurrenceType?
  recurrenceEndUtc DateTime?
  priceUsd         Float
  address          String?         @db.Text
  lat              Float?
  lng              Float?
  published        Boolean         @default(false)
  status           LessonStatus    @default(CREATED)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  cancelRequests   LessonCancellationRequest[]
  exceptions       LessonException[]
  resources        LessonResource[]

  @@index([teacherId, startsAtUtc])
  @@index([studentId, startsAtUtc])
  @@index([published, startsAtUtc])
}

enum CancelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model LessonCancellationRequest {
  id               String              @id @default(cuid())
  lesson           Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId         String
  student          Student             @relation(fields: [studentId], references: [id])
  studentId        String
  requestedDateUtc DateTime
  reason           String?             @db.Text
  status           CancelRequestStatus @default(PENDING)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([lessonId, requestedDateUtc, studentId])
  @@index([lessonId, requestedDateUtc])
  @@index([studentId, status])
}

enum LessonExceptionType {
  CANCELLED
}

model LessonException {
  id        String              @id @default(cuid())
  lesson    Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String
  dateUtc   DateTime
  type      LessonExceptionType
  reason    String?             @db.Text
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([lessonId, dateUtc], name: "lessonId_dateUtc")
}

model LessonResource {
  id          String   @id @default(cuid())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  title       String
  contentHtml String   @db.LongText
  links       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  TEACHER
  STUDENT
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  oauth_token_secret String? @db.Text
  oauth_token        String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Summer Camps ─────────────────────────────────────────────────────────────

enum CampStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ACTIVE
  WITHDRAWN
}

model SummerCamp {
  id          String       @id @default(cuid())
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  teacherId   String
  name        String
  description String?      @db.Text
  ageMin      Int?
  ageMax      Int?
  focus       String?      // "Piano", "Voice", "General Music", etc.
  startDate   DateTime     // UTC start of first session
  endDate     DateTime     // UTC end of last session
  capacity    Int          @default(10)
  priceUsd    Float        @default(0)
  address     String?      @db.Text
  lat         Float?
  lng         Float?
  published   Boolean      @default(false)
  status      CampStatus   @default(DRAFT)
  locale      String       @default("en")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  sessions    CampSession[]
  enrollments CampEnrollment[]

  @@index([teacherId, startDate])
  @@index([published, startDate])
}

model CampSession {
  id          String     @id @default(cuid())
  camp        SummerCamp @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId      String
  title       String?
  startsAtUtc DateTime
  durationMin Int        @default(60)
  timezone    String     @default("America/Chicago")
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  resources   CampSessionResource[]

  @@index([campId, startsAtUtc])
}

model CampSessionResource {
  id          String      @id @default(cuid())
  session     CampSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  title       String
  contentHtml String      @db.LongText
  links       Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model CampEnrollment {
  id         String           @id @default(cuid())
  camp       SummerCamp       @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId     String
  student    Student          @relation(fields: [studentId], references: [id])
  studentId  String
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([campId, studentId])
  @@index([studentId])
  @@index([campId])
}

// --- Marketing / Homepage PageBuilder ---
enum PageBlockType {
  HERO
  CHALLENGE
  CURVED_ROW
  GRID_CARDS
  AUDIO_LIST
  SPOTLIGHT
  EVENTS
  NEWSLETTER
  WHATSAPP
  BLOG_CARDS
}

model PageBlock {
  id        String        @id @default(cuid())
  type      PageBlockType
  path      String        @default("/")
  locale    String        @default("en")
  position  Int           @default(0)
  data      Json
  audiences Json?
  published Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([path, locale, published, position])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  source    String?  // e.g. "homepage"
  createdAt DateTime @default(now())
}

model EventLog {
  id        String   @id @default(cuid())
  action    String
  block     String
  path      String
  locale    String   @default("en")
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  targetId  String?
  path      String?
  locale    String?  @default("en")
  meta      Json?
  createdAt DateTime @default(now())
}

// --- Blog ---
model BlogPost {
  id        String   @id @default(cuid())
  locale    String   @default("en")
  title     String
  slug      String
  excerpt   String?  @db.Text
  tag       String?
  imageUrl  String?  @db.Text
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, slug], name: "blog_locale_slug")
  @@index([locale, published, createdAt])
}

// --- Social Links ---
enum SocialProvider {
  FACEBOOK
  INSTAGRAM
  YOUTUBE
  TIKTOK
  TWITTER
  WHATSAPP
  LINKEDIN
}

model SocialLink {
  id        String         @id @default(cuid())
  provider  SocialProvider
  label     String
  url       String         @db.Text
  iconUrl   String?        @db.Text
  order     Int            @default(0)
  enabled   Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// --- Marketing: Home Slider ---
model SliderItem {
  id           String   @id @default(cuid())
  locale       String   @default("en")
  title        String
  subtitle     String?  @db.Text
  imageUrl     String   @db.Text
  buttonLabel  String?
  buttonHref   String?  @db.Text
  buttonTarget String   @default("_self") // "_self" | "_blank"
  order        Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SliderConfig {
  id            String   @id @default(cuid())
  locale        String   @unique @default("en")
  intervalMs    Int      @default(6500)
  transition    String   @default("fade")     // "fade" | "slide"
  textAnimation String   @default("fade-up")  // "none" | "fade" | "fade-up"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

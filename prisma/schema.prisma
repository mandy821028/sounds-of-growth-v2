// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
 
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  firstName      String
  lastName       String
  phone          String?
  locale         String    @default("en")
  role           Role      @default(STUDENT)
  mustChangePassword Boolean @default(false)
  teacher        Teacher?
  student        Student?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
}

model Teacher {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String    @unique
  students  Student[]
  lessons   Lesson[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Student {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @unique
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  teacherId    String
  dateOfBirth  DateTime
  address      String?
  lat          Float?
  lng          Float?
  lessons      Lesson[]
  cancelRequests LessonCancellationRequest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ClassType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lessons   Lesson[]
}

enum LessonStatus {
  CREATED
  CANCELLED
  COMPLETED
}

model Lesson {
  id           String       @id @default(cuid())
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  teacherId    String
  student      Student      @relation(fields: [studentId], references: [id])
  studentId    String
  classType    ClassType    @relation(fields: [classTypeId], references: [id])
  classTypeId  String
  startsAtUtc  DateTime
  durationMin  Int
  timezone     String
  recurrence   String?
  recurrenceEndUtc DateTime?
  priceUsd     Float
  address      String?
  lat          Float?
  lng          Float?
  published    Boolean @default(false)
  status       LessonStatus @default(CREATED)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cancelRequests LessonCancellationRequest[]
  exceptions   LessonException[]
  resources    LessonResource[]
}

enum CancelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model LessonCancellationRequest {
  id        String  @id @default(cuid())
  lesson    Lesson  @relation(fields: [lessonId], references: [id])
  lessonId  String
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  requestedDateUtc DateTime
  reason    String?
  status    CancelRequestStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LessonExceptionType {
  CANCELLED
}

model LessonException {
  id        String  @id @default(cuid())
  lesson    Lesson  @relation(fields: [lessonId], references: [id])
  lessonId  String
  dateUtc   DateTime
  type      LessonExceptionType
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lessonId, dateUtc], name: "lessonId_dateUtc")
}

model LessonResource {
  id          String   @id @default(cuid())
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  lessonId    String
  title       String
  contentHtml String   // stored rich-text HTML
  links       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  TEACHER
  STUDENT
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Marketing / Homepage PageBuilder ---
enum PageBlockType {
  HERO
  CHALLENGE
  CURVED_ROW
  GRID_CARDS
  AUDIO_LIST
  SPOTLIGHT
  EVENTS
  NEWSLETTER
  WHATSAPP
  BLOG_CARDS
}

model PageBlock {
  id        String        @id @default(cuid())
  type      PageBlockType
  path      String        @default("/") // route where it will render, e.g. "/" for homepage
  locale    String        @default("en")
  position  Int           @default(0)
  data      Json          // arbitrary props for the block (title, subtitle, items, media, etc.)
  audiences Json?         // e.g. ["PARENTS","STUDENTS","TEACHERS"], null => all
  published Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  source    String?  // e.g. "homepage"
  createdAt DateTime @default(now())
}

model EventLog {
  id        String   @id @default(cuid())
  action    String   // PLAY | CLICK | SUBSCRIBE | VIEW
  block     String   // AUDIO_LIST | NEWSLETTER | WHATSAPP | SPOTLIGHT | EVENTS | ...
  path      String
  locale    String   @default("en")
  meta      Json?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  targetId  String?
  path      String?
  locale    String?  @default("en")
  meta      Json?
  createdAt DateTime @default(now())
}

// --- Blog ---
model BlogPost {
  id        String   @id @default(cuid())
  locale    String   @default("en")
  title     String
  slug      String
  excerpt   String?
  tag       String?
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, slug], name: "blog_locale_slug")
}

// --- Social Links ---
enum SocialProvider {
  FACEBOOK
  INSTAGRAM
  YOUTUBE
  TIKTOK
  TWITTER
  WHATSAPP
  LINKEDIN
}

model SocialLink {
  id        String         @id @default(cuid())
  provider  SocialProvider
  label     String
  url       String
  iconUrl   String?
  order     Int            @default(0)
  enabled   Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// --- Marketing: Home Slider ---
model SliderItem {
  id           String   @id @default(cuid())
  locale       String   @default("en")
  title        String
  subtitle     String?
  imageUrl     String
  buttonLabel  String?
  buttonHref   String?
  buttonTarget String   @default("_self") // "_self" | "_blank"
  order        Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SliderConfig {
  id            String   @id @default(cuid())
  locale        String   @unique @default("en")
  intervalMs    Int      @default(6500)
  transition    String   @default("fade")     // "fade" | "slide"
  textAnimation String   @default("fade-up")  // "none" | "fade" | "fade-up"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
